# ── MongoDB ───────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=news_aggregation

# ── Application ───────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
FEED_REFRESH_INTERVAL_MINUTES=30

# ── Optional API keys ─────────────────────────────────────────────────────
# Obtain from https://newsapi.org  — leave blank to skip
NEWSAPI_KEY=

# Obtain from https://gnews.io — leave blank to skip
GNEWS_API_KEY=
