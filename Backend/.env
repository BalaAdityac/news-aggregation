# ── MongoDB ───────────────────────────────────────────────────────────────
# When running locally (not via Docker Compose), keep this pointing to localhost.
# When running inside Docker Compose, this is overridden to mongodb://mongo:27017
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=news_aggregation

# ── Application ───────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# How often (in minutes) the aggregator re-fetches all sources
FEED_REFRESH_INTERVAL_MINUTES=30

# ── Optional API keys ─────────────────────────────────────────────────────
# Leave blank to skip that provider; the app handles missing keys gracefully.
NEWSAPI_KEY=
GNEWS_API_KEY=
